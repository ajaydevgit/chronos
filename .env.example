# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,chronos-backend

# Database
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=chronos_db
DATABASE_USER=chronos_user
DATABASE_PASSWORD=chronos_password
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j_password

# ChromaDB
CHROMADB_HOST=chroma
CHROMADB_PORT=8000
CHROMADB_COLLECTION_NAME=chronos_events

# LLM Settings
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7

# Local LLM (if using local provider)
LOCAL_LLM_URL=http://localhost:8001
LOCAL_LLM_MODEL=llama-2

# Sentence Transformers
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-password

# Security
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# API Settings
API_RATE_LIMIT=10
API_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Frontend
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_GRAPH_API_URL=http://localhost:8000/api/v1/graph

# Redis (optional, for caching)
REDIS_URL=redis://redis:6379/0

# Celery (optional, for async tasks)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
